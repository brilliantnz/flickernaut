{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true,
    "rootDir": ".",
    "outDir": "./dist",
    "sourceMap": false,
    "paths": {
      "#/*": ["./src/*"]
    }
  },
  "include": ["src/ambient.d.ts", "./src/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
