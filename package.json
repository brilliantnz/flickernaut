{
  "name": "flickernaut",
  "version": "1.0.0",
  "private": true,
  "description": "An extension that adds quick-launch to Nautilus context menu entries",
  "homepage": "https://github.com/brilliantnz/flickernaut#readme",
  "bugs": {
    "url": "https://github.com/brilliantnz/flickernaut/issues"
  },
  "license": "GPL-3.0-or-later",
  "author": "Brilliant Nurzaman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brilliantnz/flickernaut.git"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "make all",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --strict --noEmit"
  },
  "dependencies": {
    "@girs/gjs": "4.1.0",
    "@girs/gnome-shell": "50.0.3"
  },
  "devDependencies": {
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3"
  }
}
